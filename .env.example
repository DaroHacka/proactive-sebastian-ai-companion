# Ollama Configuration
OLLAMA_URL=http://localhost:11434
COMPANION_MODEL=phi4

# Model Configuration
AGENT_MODEL=qwen3:14b

# Scheduler Configuration
SCHEDULER_INTERVAL_MINUTES=5
AUTOMATIC_ENABLED=true

# Cue Configuration (response variation)
CUE_ENABLED=true
CUE_PROBABILITY=0.2  # 20% chance of applying cue per message (0.0-1.0)

# Memory Management
MAX_MEMORY_ENTRIES=50  # Maximum entries per memory tier (fresh, medium, longterm)
ARCHIVE_THRESHOLD=30   # Days before entries are archived to next tier

# File Paths
INTENT_FILE=interaction_intents.txt
STATE_FILE=state.json
APPOINTMENTS_FILE=appointments.json

# Legacy/Optional
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
USER_EMAIL=your_personal_email
INACTIVITY_CHECK_MINUTES=30
WORRY_THRESHOLD_HOURS=3
