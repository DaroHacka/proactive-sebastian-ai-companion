# Open WebUI API
WEBUI_API_URL=http://localhost:3000/api
API_KEY=your_api_key_here

# Model Configuration
COMPANION_MODEL=phi4
AGENT_MODEL=qwen3:14b

# Email Configuration
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# User Configuration (the person Sebastian checks on)
USER_EMAIL=your_personal_email

# Intent File
INTENT_FILE=interaction_intents.txt

# State File
STATE_FILE=state.json

# Appointments File
APPOINTMENTS_FILE=appointments.json

# Inactivity Check (minutes)
INACTIVITY_CHECK_MINUTES=30

# Worry Threshold (hours)
WORRY_THRESHOLD_HOURS=3